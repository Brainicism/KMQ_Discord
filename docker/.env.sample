# This file lives at docker/.env and is loaded automatically by the
# `npm run docker-compose-*` scripts — both for build-arg substitution
# (docker-compose's ${VAR} interpolation) and for runtime env injection
# (env_file: .env in docker-compose.yml). A project-root .env is NOT
# consulted by the docker-compose flow; only the `docker-run-internal`
# script reads it via `. ./.env` at container launch.
#
# If you use `npm run docker-build` directly, be aware docker build does
# not read any .env file — pass --build-arg BOT_CLIENT_ID=... explicitly
# or switch to the compose-based scripts.

BOT_TOKEN=
DB_USER=root
DB_PASS=db_pass
DB_HOST=db
DB_PORT=3306
BOT_PREFIX=,
WEB_SERVER_PORT=5858

# ---------- Discord Activity (optional) ----------
# Required to enable the embedded iframe Activity. Leave blank to run the
# bot without Activity support; /api/activity/* routes still exist but will
# 500 on token exchange.
#
# BOT_CLIENT_ID:      Your bot's Discord application ID. Used by the
#                     server at runtime AND baked into the Activity JS
#                     bundle at build time (see activity/vite.config.ts).
# DISCORD_CLIENT_SECRET:
#                     Your Discord application's client secret, used for
#                     the OAuth2 `authorization_code` exchange.
# ACTIVITY_PUBLIC_BASE_URL:
#                     Public HTTPS origin of the Activity (the URL you
#                     registered as a URL Mapping in the Discord developer
#                     portal).
BOT_CLIENT_ID=
DISCORD_CLIENT_SECRET=
ACTIVITY_PUBLIC_BASE_URL=
