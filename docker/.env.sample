BOT_TOKEN=
DB_USER=root
DB_PASS=db_pass
DB_HOST=db
DB_PORT=3306
BOT_PREFIX=,
WEB_SERVER_PORT=5858

# ---------- Discord Activity (optional) ----------
# Required to enable the embedded iframe Activity. Leave blank to run the
# bot without Activity support; /api/activity/* routes still exist but will
# 500 on token exchange.
#
# BOT_CLIENT_ID:      Your bot's Discord application ID (same as the bot
#                     the Activity is attached to).
# DISCORD_CLIENT_SECRET:
#                     Your Discord application's client secret, used for
#                     the OAuth2 `authorization_code` exchange.
# ACTIVITY_PUBLIC_BASE_URL:
#                     Public HTTPS origin of the Activity (the URL you
#                     registered as a URL Mapping in the Discord developer
#                     portal).
# VITE_DISCORD_CLIENT_ID:
#                     Build-time only — read by Vite and baked into the
#                     Activity JS bundle. Must equal BOT_CLIENT_ID. Set
#                     via `docker compose build --build-arg VITE_DISCORD_CLIENT_ID=...`
#                     (or a matching `args:` block in your compose file).
BOT_CLIENT_ID=
DISCORD_CLIENT_SECRET=
ACTIVITY_PUBLIC_BASE_URL=
