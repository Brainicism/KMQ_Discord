{
    "name": "kmq",
    "version": "9.9.1",
    "main": "src/kmq.js",
    "scripts": {
        "seed": ". ./.env && ts-node --swc src/seed/seed_db",
        "bootstrap": "ts-node --swc src/seed/bootstrap.ts",
        "start": "./start.sh native",
        "dry-run": "NODE_ENV=dry-run npm run start",
        "dev-tsc": "NODE_ENV=development npm run start",
        "dev": "NODE_ENV=development_ts_node npm run start",
        "dev-god": "NODE_ENV=development_ts_node GOD_MODE=true npm run start",
        "dev-minimal": "NODE_ENV=development_ts_node MINIMAL_RUN=true npm run start",
        "ci": "NODE_ENV=ci npm run start",
        "prod": "NODE_ENV=production npm run start",
        "clean": "rm -rf build/ && rm -f tsconfig.tsbuildinfo",
        "download-songs": "ts-node --swc src/scripts/download-new-songs.ts",
        "lint": "npx eslint --cache src/",
        "lint-i18n": "npx eslint --config eslint.config.i18n.mjs --fix i18n/",
        "lint-i18n-ci": "npx eslint --config eslint.config.i18n.mjs --max-warnings=0 i18n/",
        "lint-fix": "npx eslint --fix --cache src/",
        "lint-ci": "npx eslint --cache src/ --max-warnings=0",
        "lint-all": "npm run prettier && npm run lint && npm run lint-i18n",
        "docker-compose-db": "cd docker/ && docker-compose up -d db",
        "docker-compose-dev": "cd docker/ && NODE_ENV=development docker-compose up  --exit-code-from kmq --build kmq",
        "docker-compose-dryrun": "cd docker/ && NODE_ENV=dry-run docker-compose up --exit-code-from kmq --build kmq",
        "docker-build": "cd docker/ && DOCKER_BUILDKIT=1 docker build -f kmq/Dockerfile -t ghcr.io/brainicism/kmq_discord:latest ../",
        "docker-run": "bash src/scripts/docker-run.sh",
        "docker-run-internal": ". ./.env && docker run --restart unless-stopped -d -v ${SONG_DOWNLOAD_DIR}:${SONG_DOWNLOAD_DIR} -v ${PWD}/data:/app/data -v ${PWD}/.env:/app/.env -v ${PWD}/logs:/app/logs -v ${PWD}/sql_dumps:/app/sql_dumps --env NODE_ENV=production --env IS_STANDBY=${IS_STANDBY:=false} --network=host --name ${APP_NAME} ${IMAGE_NAME:=ghcr.io/brainicism/kmq_discord:latest}",
        "docker-run-bgutil": "docker run --restart unless-stopped -d --network=host --name bgutil-ytdlp-pot-provider ghcr.io/brainicism/bgutil-ytdlp-pot-provider:latest",
        "docker-stop": "docker stop ${APP_NAME}",
        "backup": "ts-node --swc src/scripts/backup-kmq-database",
        "import": "ts-node --swc src/scripts/backup-kmq-database --import",
        "regenerate-test-db-dump": "NODE_ENV=test ts-node src/scripts/regenerate-test-db-dump",
        "test": "NODE_ENV=test mocha -r ts-node/register 'src/test/unit_tests/**/*.ts'",
        "test-ci": "NODE_ENV=test mocha -- --forbid-only -r ts-node/register 'src/test/unit_tests/**/*.ts'",
        "prepare-schema": "bash src/scripts/prepare-kysely-schema.sh",
        "prettier": "prettier --write '**/*.{js,ts}'",
        "prettier-ci": "prettier --check '**/*.{js,ts}'",
        "missing-i18n": "ts-node src/ci_checks/missing_i18n.ts $(find src -name '*.ts' -print)"
    },
    "author": "Brian Le",
    "license": "GPL-3.0",
    "dependencies": {
        "@commander-js/extra-typings": "^14.0.0",
        "@discordjs/opus": "^0.10.0",
        "@fastify/view": "^11.1.1",
        "@google/generative-ai": "^0.24.1",
        "@swc-node/register": "^1.11.1",
        "@swc/core": "^1.15.32",
        "@types/damerau-levenshtein": "^1.0.2",
        "@types/ejs": "^3.1.5",
        "@types/fluent-ffmpeg": "^2.1.28",
        "@types/i18next-fs-backend": "^1.2.0",
        "@types/lodash": "^4.17.24",
        "@types/mocha": "^10.0.10",
        "@types/node-schedule": "^2.1.8",
        "@types/sinon": "^21.0.1",
        "@types/tiny-async-pool": "^2.0.3",
        "@types/uuid": "^11.0.0",
        "@typescript-eslint/eslint-plugin": "^6.20.0",
        "@typescript-eslint/parser": "^6.20.0",
        "async-mutex": "^0.5.0",
        "axios": "^1.15.2",
        "bgutils-js": "^3.2.0",
        "bufferutil": "^4.1.0",
        "commander": "^14.0.3",
        "damerau-levenshtein": "^1.0.8",
        "dotenv": "^17.4.2",
        "ejs": "^5.0.2",
        "eris": "https://github.com/Brainicism/eris#0114e58",
        "eris-fleet": "https://github.com/Brainicism/eris-fleet#9916334",
        "eris-pagination": "https://github.com/Brainicism/eris-pagination#e2c01f2",
        "fastify": "^5.8.5",
        "fluent-ffmpeg": "^2.1.3",
        "googleapis": "^171.4.0",
        "googlevideo": "^1.1.0",
        "i18next": "^26.0.8",
        "i18next-fs-backend": "^2.6.5",
        "jsdom": "^29.1.1",
        "kysely": "^0.28.16",
        "lodash": "^4.18.1",
        "mocha": "^11.7.5",
        "moment-timezone": "^0.6.2",
        "mysql2": "^3.22.3",
        "node-schedule": "^2.1.1",
        "pako": "^2.1.0",
        "sinon": "^21.1.2",
        "sodium-native": "^5.1.0",
        "tiny-async-pool": "^2.1.0",
        "ts-node": "^10.9.2",
        "uuid": "^14.0.0",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0",
        "youtubei.js": "^17.0.1"
    },
    "devDependencies": {
        "@types/jsdom": "^28.0.1",
        "eslint": "^9.9.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-i18n-json": "https://github.com/godaddy/eslint-plugin-i18n-json#13d5f18",
        "eslint-plugin-jsdoc": "^50.6.17",
        "eslint-plugin-only-warn": "^1.2.1",
        "eslint-plugin-tsdoc": "^0.5.2",
        "i18n-ai-translate": "^4.1.2",
        "kysely-codegen": "^0.20.0",
        "prettier": "3.8.3",
        "typescript": "^5.5.4",
        "typescript-eslint": "^8.59.1",
        "@eslint/js": "^9.9.1",
        "@eslint/eslintrc": "^3.3.1",
        "globals": "^17.6.0",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "@stylistic/eslint-plugin": "^5.10.0"
    },
    "description": "K-pop guessing game over Discord"
}
